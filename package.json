{
	"name": "repo-starter-kit",
	"description": "CLI to bootstrap and sync repository labels, issues, branch rulesets and config.",
	"version": "0.5.0",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/repo-starter-kit",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/repo-starter-kit.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/repo-starter-kit/discussions/categories/issue-triage"
	},
	"engines": {
		"node": ">=18.20"
	},
	"type": "module",
	"bin": {
		"repo-starter-kit": "bin/repo-starter-kit"
	},
	"main": "lib/cli.js",
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run compile:src",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:all": "npm audit && npm run lint:package && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"lint:package": "fixpack || true",
		"prepack": "npm run build",
		"prepare": "husky; npm run lint:package",
		"release": "release-it",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run --update",
		"update:deps": "taze; taze --all",
		"watch:build": "tsc-watch -p src --onSuccess 'npm run build'",
		"watch:src": "tsc-watch -p src"
	},
	"dependencies": {
		"@octokit/auth-oauth-device": "8.0.3",
		"@octokit/rest": "22.0.1",
		"@octokit/types": "16.0.0",
		"@zokugun/cli-utils": "0.3.1",
		"@zokugun/fs-extra-plus": "0.3.7",
		"@zokugun/is-it-type": "0.8.1",
		"@zokugun/xtry": "0.11.4",
		"clipboardy": "5.3.1",
		"execa": "9.6.1",
		"gray-matter": "4.0.3",
		"open": "11.0.0",
		"pacote": "21.5.0",
		"playwright": "1.59.1",
		"tempy": "3.2.0",
		"trash": "10.1.1",
		"untildify": "6.0.0",
		"yaml": "2.8.3"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.2",
		"@commitlint/config-conventional": "20.5.0",
		"@types/node": "22.13.14",
		"@types/pacote": "11.1.8",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.0.1",
		"rimraf": "6.1.3",
		"taze": "19.11.0",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"xo": "0.60.0"
	},
	"keywords": [
		"automation",
		"cli",
		"github",
		"issues",
		"labels",
		"repo",
		"starter"
	]
}
